      "parameters": {
        "functionCode": "// Połącz dane Proxmox z pytaniem z Telegrama\nconst parseNode = $('PARSE TG MESSAGE').item.json;\nconst question = parseNode.question || 'status';\nconst chatId = parseNode.chatId || 'unknown';\nconst username = parseNode.username || 'unknown';\n\nconst vm = items[0].json.data || [];\nconst ct = items[1].json.data || [];\nconst node = items[2].json.data || {};\n\nconst cpuPercent = node.cpu ? Math.round(node.cpu * 100) : 0;\nconst ramPercent = node.memory ? Math.round((node.memory.used / node.memory.total) * 100) : 0;\n\nconst systemPrompt = `Jesteś asystentem DevOps dla serwera Proxmox VE (node: grupadm2).\nUżytkownik wysyła pytania przez Telegram.\nOdpowiadaj ZWIĘŹLE (max 3-4 zdania dla Telegrama). Używaj emoji.\n\nAktualne dane Proxmox:\n=== NODE ===\nCPU: ${cpuPercent}% | RAM: ${ramPercent}%\n${JSON.stringify(node, null, 2)}\n\n=== VMs ===\n${JSON.stringify(vm, null, 2)}\n\n=== CT ===\n${JSON.stringify(ct, null, 2)}\n\nUżytkownik: ${username}`;\n\nreturn [{\n  json: {\n    systemPrompt,\n    userMessage: question,\n    chatId,\n    username\n  }\n}];"
      },
