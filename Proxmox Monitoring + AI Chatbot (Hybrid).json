        "functionCode": "let raw;\n\ntry {\n  raw = $json.content.parts[0].text;\n} catch (e) {\n  return [{ json: { status: \"ERROR\", email_html: \"<h2>AI ERROR</h2>\" } }];\n}\n\nraw = raw.replace(/```json/g,'').replace(/```/g,'').trim();\n\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\n\nif(!match){\n  return [{ json: { status:\"ERROR\", email_html:\"<h2>NO JSON</h2>\" } }];\n}\n\ntry {\n  return [{ json: JSON.parse(match[0]) }];\n} catch (e) {\n  return [{ json: { status:\"ERROR\", email_html:\"<h2>PARSE ERROR</h2>\" } }];\n}\n"
      },
