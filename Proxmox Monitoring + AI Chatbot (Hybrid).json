        "functionCode": "const { vm, ct, node } = $json;\n\nreturn [{\n  json: {\n    prompt: `\nJesteś DevOps AI.\n\nWygeneruj raport Proxmox.\n\nWAŻNE:\n- NIE skracaj HTML\n- NIE używaj ...\n- każdy HTML musi być zamknięty\n\n=== NODE grupadm2 ===\n${JSON.stringify(node, null, 2)}\n\n=== VM ===\n${JSON.stringify(vm, null, 2)}\n\n=== CT ===\n${JSON.stringify(ct, null, 2)}\n\nDODAJ kolumnę \"Uwagi\":\n- running = OK\n- stopped = Maszyna zatrzymana\n- template = Szablon\n- cpu > 80% = Wysokie CPU\n- ram > 80% = Wysokie RAM\n\nOUTPUT TYLKO JSON:\n{\n  \"status\": \"OK\" | \"ALERT\",\n  \"message\": \"string\",\n  \"email_html\": \"FULL HTML 3 TABLES\"\n}\n`\n  }\n}];"
